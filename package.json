{
  "name": "srcm",
  "version": "0.1.0",
  "description": "Sistema de Rastreabilidade e Controle de Materiais",
  "type": "module",
  "engines": {
    "node": ">=18.0.0"
  },
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src tests --ext .ts,.tsx",
    "lint:fix": "eslint . --ext ts,tsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\" \"tests/**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@solidjs/router": "^0.14.4",
    "solid-js": "^1.9.4"
  },
  "devDependencies": {
    "@solidjs/testing-library": "^0.8.10",
    "@testing-library/jest-dom": "^6.6.3",
    "@types/node": "^22.10.1",
    "typescript-eslint": "^8.16.0",
    "@eslint/js": "^9.16.0",
    "eslint": "^9.16.0",
    "eslint-plugin-solid": "^0.14.4",
    "jsdom": "^25.0.1",
    "prettier": "^3.4.2",
    "typescript": "~5.6.2",
    "vite": "^5.4.11",
    "vite-plugin-solid": "^2.10.2",
    "vitest": "^2.1.6"
  }
}
